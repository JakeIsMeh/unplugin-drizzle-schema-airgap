{
	"name": "unplugin-drizzle-schema-airgap",
	"version": "0.1.0",
	"description": "Compile-time airgap Drizzle schemas for client validation libraries",
	"keywords": [
		"airgap",
		"arktype",
		"build-time",
		"bun",
		"compile-time",
		"drizzle",
		"drizzle-orm",
		"effect",
		"effect-schema",
		"esbuild",
		"farm",
		"rolldown",
		"rollup",
		"rsbuild",
		"rspack",
		"standard-schema",
		"typebox",
		"unplugin",
		"valibot",
		"validation",
		"vite",
		"webpack",
		"zod"
	],
	"license": "ISC",
	"author": "",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./vite": {
			"import": "./dist/vite.js",
			"require": "./dist/vite.cjs",
			"types": "./dist/vite.d.ts"
		},
		"./rolldown": {
			"import": "./dist/rolldown.js",
			"require": "./dist/rolldown.cjs",
			"types": "./dist/rolldown.d.ts"
		},
		"./rollup": {
			"import": "./dist/rollup.js",
			"require": "./dist/rollup.cjs",
			"types": "./dist/rollup.d.ts"
		},
		"./rspack": {
			"import": "./dist/rspack.js",
			"require": "./dist/rspack.cjs",
			"types": "./dist/rspack.d.ts"
		},
		"./esbuild": {
			"import": "./dist/esbuild.js",
			"require": "./dist/esbuild.cjs",
			"types": "./dist/esbuild.d.ts"
		},
		"./webpack": {
			"import": "./dist/webpack.js",
			"require": "./dist/webpack.cjs",
			"types": "./dist/webpack.d.ts"
		},
		"./rsbuild": {
			"import": "./dist/rsbuild.js",
			"require": "./dist/rsbuild.cjs",
			"types": "./dist/rsbuild.d.ts"
		},
		"./farm": {
			"import": "./dist/farm.js",
			"require": "./dist/farm.cjs",
			"types": "./dist/farm.d.ts"
		},
		"./bun": {
			"import": "./dist/bun.js",
			"require": "./dist/bun.cjs",
			"types": "./dist/bun.d.ts"
		}
	},
	"scripts": {
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"test:ci": "vitest run",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"build": "pnpm run typecheck && tsdown"
	},
	"dependencies": {
		"jiti": "^2.7.0",
		"oxc-parser": "^0.138.0",
		"tinyglobby": "^0.2.17",
		"unplugin": "^3.3.0"
	},
	"devDependencies": {
		"@rsbuild/core": "^2.1.2",
		"@rspack/core": "^2.1.2",
		"@sinclair/typebox": "^0.34.49",
		"@types/node": "^26.0.1",
		"arktype": "^2.2.1",
		"drizzle-orm": "1.0.0-rc.4",
		"elysia": "^1.4.29",
		"nitro": "3.0.260610-beta",
		"nuxt": "^4.4.8",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.23.0",
		"pnpm": "11.9.0",
		"rolldown": "^1.1.3",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"valibot": "^1.4.2",
		"vite": "^8.1.0",
		"vitest": "^4.1.9",
		"vue": "^3.5.39",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@effect/schema": "*",
		"@sinclair/typebox": ">=0.30.0",
		"arktype": ">=2.0.0",
		"drizzle-orm": ">=0.30.0",
		"valibot": ">=0.30.0",
		"zod": "^3.0.0 || ^4.0.0"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		},
		"valibot": {
			"optional": true
		},
		"@sinclair/typebox": {
			"optional": true
		},
		"arktype": {
			"optional": true
		},
		"@effect/schema": {
			"optional": true
		}
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.6.0",
			"onFail": "download"
		}
	}
}
