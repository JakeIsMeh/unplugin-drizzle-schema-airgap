{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"rootDirs": ["./src", "./tests"],
		"outDir": "./dist"
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"test-artifacts",
		"tests/fixtures/.generated",
		"tests/fixtures/.generated-rspack",
		"tests/fixtures/nuxt-app",
		"tests/fixtures/nitro-app"
	]
}
